generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Store {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String     @unique
  logoUrl   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  discounts Discount[]
  leaflets  Leaflet[]
  products  Product[]

  @@map("stores")
}

model Product {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  imageUrl    String?    @map("image_url")
  // GTIN-13/14 from Wolt's `barcode_gtin`. Canonical cross-chain key.
  // NULL for items not yet linked to Wolt (Lidl, fresh produce, chain-exclusive).
  barcode     String?    @unique
  // Pre-extracted brand (Wolt manufacturerName / Masoutis BrandNameDescr).
  brand       String?
  // Unit info "650 g" / "1 L" — used for per-unit price display.
  unitInfo    String?    @map("unit_info")
  woltId      String?    @unique @map("wolt_id")
  supermarket String?    // legacy: first chain to surface this product. Deprecated, kept for back-compat.
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  storeId     String     @db.Uuid @map("store_id")
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  discounts   Discount[]
  priceSnapshots PriceSnapshot[]
  pendingMatches PendingMatch[]
  matchCache  MatchCache[]
  chainMappings ChainProductMapping[]

  @@index([storeId])
  @@index([supermarket])
  @@index([updatedAt])
  @@index([brand])
  @@map("products")
}

model PriceSnapshot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  supermarket     String
  price           Float
  isDiscounted    Boolean  @default(false) @map("is_discounted")
  // Phase 9: what this price point IS — 'normal' (full-catalog shelf price,
  // no promo), 'strikethrough' (published original→offer), or 'mono'
  // (reference price hidden). null = legacy snapshot (all offer-derived,
  // recorded before the full-catalog baseline existed). `isDiscounted` is the
  // back-compat boolean; `kind` is the richer signal the baseline/verdict use.
  kind            String?
  recordedAt      DateTime @default(now()) @map("recorded_at")
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, recordedAt])
  @@index([productId, kind, recordedAt])
  @@map("price_snapshots")
}

model Leaflet {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String?
  validFrom  DateTime?
  validUntil DateTime?
  pdfUrl     String?
  autoDeleteDays Int?
  pageImages String[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  storeId    String     @db.Uuid
  discounts  Discount[]
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([validUntil])
  @@map("leaflets")
}

model Discount {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productName     String   @map("product_name")
  // Top-level department (one of lib/categories.ts DEPARTMENTS) — drives the
  // CategoryGrid + filters. Assigned by the keyword categorizer at write time.
  category        String
  // The chain's own native category label (kritikos "Ελαιόλαδο Έξτρα Παρθένο",
  // mymarket analytics category, …), preserved for future subcategory drill-down.
  // Null when the source exposes none (e.g. masoutis).
  subcategory     String?
  originalPrice   Float?   @map("original_price")
  discountedPrice Float    @map("discounted_price")
  discountPercent Float?   @map("discount_percent")
  // Why this is an offer (Phase 9): 'strikethrough' = chain published an
  // original→offer price (real % is provable); 'mono' = "ΜΟΝΟ x€"-style promo
  // where the chain HIDES the reference price (delta inferred from the
  // full-catalog baseline). null = adapter didn't classify / legacy row.
  offerType       String?  @map("offer_type")
  validFrom       DateTime @map("valid_from")
  validUntil      DateTime @map("valid_until")
  imageUrl        String?  @map("image_url")
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  storeId         String   @db.Uuid @map("store_id")
  leafletId       String?  @db.Uuid @map("leaflet_id")
  isActive        Boolean  @default(true) @map("is_active")
  supermarket     String?  // The slug like "ab", "lidl"
  productId       String?  @db.Uuid @map("product_id")
  isFeatured      Boolean  @default(false) @map("is_featured")
  featuredUntil   DateTime? @map("featured_until")
  featuredLabel   String?  @map("featured_label")
  source          String   @default("web") // "web" | "leaflet" | "manual"
  // Merchandising rank (fylladio-style): KVI/brand/mechanic/% + clicks + recency.
  // Computed at write (src/lib/hotness.ts) and recomputed daily by the
  // recompute-hotness cron. Default sort for the public deal lists.
  hotScore        Float    @default(0) @map("hot_score")
  // Lifetime deal_click count; bumped in track-event, used as the popularity
  // signal in the daily hotScore recompute (windowed there, cumulative here).
  clickCount      Int      @default(0) @map("click_count")
  // Honest price verdict for THIS offer vs the product's 90-day price history
  // ('lowest' | 'good' | 'fair' | 'meh' | 'high'). Only positive verdicts are
  // surfaced as a badge (lib/price-verdict.ts). Precomputed by
  // recompute-price-verdicts.mjs (daily) so card lists need no per-row query;
  // null until the next recompute pass. Detail/modal compute it live instead.
  priceVerdict    String?  @map("price_verdict")
  // The chain's own SKU for this offer — the stable dedup key that lets the
  // ingest pipeline write offers BEFORE they're matched to a Product
  // (display-first: productId null until the resolver/admin claims the row).
  // Null on legacy rows and manual/resolver-created ones.
  chainItemcode   String?  @map("chain_itemcode")
  product         Product? @relation(fields: [productId], references: [id])
  leaflet         Leaflet? @relation(fields: [leafletId], references: [id])
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([productId])
  @@index([leafletId])
  @@index([supermarket])
  @@index([category])
  @@index([validUntil])
  @@index([isActive, validUntil])
  @@index([isActive, supermarket, validUntil])
  @@index([isActive, category, validUntil])
  @@index([source])
  @@index([isActive, validUntil, hotScore])
  @@unique([supermarket, source, chainItemcode])
  @@map("discounts")
}

model ClickEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType   String   // "deal_click" | "leaflet_click" | "list_add"
  supermarket String   // slug e.g. "lidl", "ab", "sklavenitis"
  discountId  String?  @db.Uuid
  leafletId   String?  @db.Uuid
  category    String?
  sessionId   String?  // anonymous client-generated UUID from localStorage
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([supermarket, createdAt])
  @@index([eventType, createdAt])
  @@index([createdAt])
  @@map("click_events")
}

model Subscriber {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique
  confirmedAt     DateTime? @map("confirmed_at")
  confirmToken    String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("confirm_token")
  unsubToken      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("unsub_token")
  source          String?   // "homepage_footer" | "shopping_list" | etc
  preferredStores String[]  @map("preferred_stores") // supermarket slugs
  createdAt       DateTime  @default(now()) @map("created_at")
  unsubscribedAt  DateTime? @map("unsubscribed_at")
  alerts          Alert[]

  @@map("subscribers")
}

model Alert {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriberId    String    @db.Uuid @map("subscriber_id")
  keyword         String    // normalized lowercase
  supermarkets    String[]  @map("supermarkets") // empty = any
  category        String?
  maxPrice        Decimal?  @db.Decimal(10, 2) @map("max_price")
  isActive        Boolean   @default(true) @map("is_active")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  subscriber      Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([isActive, keyword])
  @@map("alerts")
}

// Persistent (rawName, supermarket) → productId mapping. Populated by matcher
// on every successful LLM match (or auto-accept). Subsequent cycles look up
// here BEFORE pre-filter / LLM, skipping the expensive call entirely. This is
// what makes the matcher scale to 10+ supermarkets on free-tier APIs.
//
// 90-day expiry on `lastUsedAt` is the cheap correctness mechanism — if a SKU
// gets renamed or recategorized, the cache row eventually retires itself.
// Manual eviction also works: DELETE FROM match_cache WHERE raw_name = '...'.
model MatchCache {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rawName     String   @map("raw_name")
  supermarket String
  productId   String   @db.Uuid @map("product_id")
  brandToken  String?  @map("brand_token")
  source      String   @default("llm") // 'llm' | 'auto_accept' — for diagnostics
  createdAt   DateTime @default(now()) @map("created_at")
  lastUsedAt  DateTime @default(now()) @map("last_used_at")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([rawName, supermarket])
  @@index([productId])
  @@index([lastUsedAt])
  @@map("match_cache")
}

// Maps each chain's internal SKU to a canonical Product. Stable identity layer:
// re-ingesting Masoutis Itemcode "2160844" always hits the same Product row —
// no fuzzy matching needed for items we've seen before. Populated by chain
// scrapers after a successful GTIN match or LLM match. The matcher's per-item
// fast path becomes:
//   1) lookup (supermarket, chainItemcode) here → done if hit
//   2) extract GTIN from chain image filename → Product.barcode match → done
//   3) fall back to existing fuzzy MatchCache + LLM flow
model ChainProductMapping {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     String   @db.Uuid @map("product_id")
  supermarket   String   // 'masoutis' | 'ab' | 'lidl' | ...
  chainItemcode String   @map("chain_itemcode") // chain's internal SKU
  createdAt     DateTime @default(now()) @map("created_at")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supermarket, chainItemcode])
  @@index([productId])
  @@map("chain_product_mappings")
}

// Flight recorder: one row per ingestOffers run (including aborted zero-item
// runs; dry runs are NOT recorded). Written by src/scripts/lib/ingest-offers.mjs,
// read by the admin "Υγεία" tab and the /api/cron/pipeline-health staleness
// alert. `priceChanges` = PriceSnapshots written this run — i.e. how much the
// chain actually changed — the signal for tuning per-chain scrape cadence.
model IngestRun {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chain        String   // chain slug — 'masoutis', 'ab', ...
  source       String   // 'web' | 'leaflet'
  startedAt    DateTime @map("started_at")
  finishedAt   DateTime @default(now()) @map("finished_at")
  scrapedItems Int      @default(0) @map("scraped_items")
  matched      Int      @default(0)
  reviewQueued Int      @default(0) @map("review_queued")
  // Of the reviewQueued items, how many were still written as visible
  // productless Discounts (display-first). 0 for chains with showUnmatched off.
  unmatchedShown Int    @default(0) @map("unmatched_shown")
  priceChanges Int      @default(0) @map("price_changes")
  deactivated  Int      @default(0)
  errors       Int      @default(0)
  healthOk     Boolean  @default(true) @map("health_ok")
  warnings     String[]

  @@index([chain, source, finishedAt])
  @@map("ingest_runs")
}

model PendingMatch {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rawName            String   @map("raw_name")
  rawPrice           Float    @map("raw_price")
  supermarket        String
  // Adapter-supplied brand (e.g. AB's manufacturerName). Persisted so the LLM
  // resolver can do brand-aware matching for chains that strip the brand from
  // the displayed product name. NULL when the adapter didn't have one.
  brand              String?
  aiConfidence       Float?   @map("ai_confidence") // 0.0 to 100.0
  suggestedProductId String?  @db.Uuid @map("suggested_product_id")
  imageUrl           String?  @map("image_url")
  createdAt          DateTime @default(now()) @map("created_at")
  product            Product? @relation(fields: [suggestedProductId], references: [id], onDelete: SetNull)

  @@unique([rawName, supermarket])
  @@index([supermarket])
  @@map("pending_matches")
}
