generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Store {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String     @unique
  logoUrl   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  discounts Discount[]
  leaflets  Leaflet[]
  products  Product[]

  @@map("stores")
}

model Product {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  imageUrl    String?    @map("image_url")
  barcode     String?
  woltId      String?    @unique @map("wolt_id")
  supermarket String?    // The slug like "ab", "lidl"
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  storeId     String     @db.Uuid @map("store_id")
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  discounts   Discount[]
  priceSnapshots PriceSnapshot[]

  @@index([storeId])
  @@index([supermarket])
  @@index([updatedAt])
  @@map("products")
}

model PriceSnapshot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId       String   @db.Uuid @map("product_id")
  supermarket     String
  price           Float
  isDiscounted    Boolean  @default(false) @map("is_discounted")
  recordedAt      DateTime @default(now()) @map("recorded_at")
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, recordedAt])
  @@map("price_snapshots")
}

model Leaflet {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String?
  validFrom  DateTime?
  validUntil DateTime?
  pdfUrl     String?
  autoDeleteDays Int?
  pageImages String[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  storeId    String     @db.Uuid
  discounts  Discount[]
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([validUntil])
  @@map("leaflets")
}

model Discount {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productName     String   @map("product_name")
  category        String
  originalPrice   Float?   @map("original_price")
  discountedPrice Float    @map("discounted_price")
  discountPercent Float?   @map("discount_percent")
  validFrom       DateTime @map("valid_from")
  validUntil      DateTime @map("valid_until")
  imageUrl        String?  @map("image_url")
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  storeId         String   @db.Uuid @map("store_id")
  leafletId       String?  @db.Uuid @map("leaflet_id")
  isActive        Boolean  @default(true) @map("is_active")
  supermarket     String?  // The slug like "ab", "lidl"
  productId       String?  @db.Uuid @map("product_id")
  isFeatured      Boolean  @default(false) @map("is_featured")
  featuredUntil   DateTime? @map("featured_until")
  featuredLabel   String?  @map("featured_label")
  product         Product? @relation(fields: [productId], references: [id])
  leaflet         Leaflet? @relation(fields: [leafletId], references: [id])
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([productId])
  @@index([leafletId])
  @@index([supermarket])
  @@index([category])
  @@index([validUntil])
  @@index([isActive, validUntil])
  @@index([isActive, supermarket, validUntil])
  @@index([isActive, category, validUntil])
  @@map("discounts")
}

model ClickEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType   String   // "deal_click" | "leaflet_click" | "list_add"
  supermarket String   // slug e.g. "lidl", "ab", "sklavenitis"
  discountId  String?  @db.Uuid
  leafletId   String?  @db.Uuid
  category    String?
  sessionId   String?  // anonymous client-generated UUID from localStorage
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([supermarket, createdAt])
  @@index([eventType, createdAt])
  @@index([createdAt])
  @@map("click_events")
}

model Subscriber {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique
  confirmedAt     DateTime? @map("confirmed_at")
  confirmToken    String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("confirm_token")
  unsubToken      String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("unsub_token")
  source          String?   // "homepage_footer" | "shopping_list" | etc
  preferredStores String[]  @map("preferred_stores") // supermarket slugs
  createdAt       DateTime  @default(now()) @map("created_at")
  unsubscribedAt  DateTime? @map("unsubscribed_at")

  @@map("subscribers")
}
