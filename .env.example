# ─── Database (Supabase Postgres) ──────────────────────────────────────────────
# Pooled connection (port 6543) — used at runtime
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by `prisma migrate`
DIRECT_URL="postgresql://postgres.<project>:<password>@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# ─── Admin auth ────────────────────────────────────────────────────────────────
# bcrypt hash of the admin password (12 rounds). Generate with:
#   node -e "require('bcryptjs').hash('your-pw', 12).then(console.log)"
# Either ADMIN_PASSWORD_HASH or ADMIN_PASSWORD_HASH_B64 must be set.
ADMIN_PASSWORD_HASH=
# Optional: same value, base64-encoded. Used as fallback when raw hash contains
# characters that some hosting envs strip (e.g. `$`).
ADMIN_PASSWORD_HASH_B64=

# 32+ random bytes, used to sign admin session JWTs (jose, HS256).
# Generate with: openssl rand -base64 48
SESSION_SECRET=

# ─── Vercel Cron auth ──────────────────────────────────────────────────────────
# Bearer token Vercel injects into scheduled requests. Must match what's
# configured in your Vercel project's Cron settings.
CRON_SECRET=

# ─── External APIs ─────────────────────────────────────────────────────────────
# Used by /api/cron/scrape-lidl for vision-based leaflet extraction (Llama-4 Scout)
GROQ_API_KEY=

# Optional: only used by ad-hoc scripts in src/scripts/* (gemini-matcher, list-models)
GEMINI_API_KEY=

# ─── Email delivery (Resend) ───────────────────────────────────────────────────
# Required for subscription-confirmation and price-alert emails. Get a key at
# https://resend.com. When unset, emails fall back to console.log (dev-only).
RESEND_API_KEY=
# Optional: sender address. Default uses Resend's onboarding@resend.dev which
# works without domain verification but ONLY delivers to the Resend account
# holder. For production, verify a domain in Resend and set e.g.:
#   EMAIL_FROM="Prosfores Pantou <alerts@prosforespantou.gr>"
EMAIL_FROM=
# Optional: Reply-To header.
EMAIL_REPLY_TO=

# ─── Public URLs (exposed to the browser) ─────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://prosforespantou.gr
NEXT_PUBLIC_BASE_URL=https://prosforespantou.gr

# ─── Sentry (auto-injected on Vercel; only set locally if uploading source maps) ─
# SENTRY_AUTH_TOKEN=
# SENTRY_DSN=
