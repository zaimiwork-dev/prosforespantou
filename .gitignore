# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# local scratch
/library_data
/test-gemini.json

# scraping debug artifacts (root-level)
/lidl_*.html
/masoutis_*.html
/masoutis_*.png
/masoutis_*.json
/masoutis_*.txt
/pending_*.json
/masoutis_leaflet_*.png
/matcher_run_*.log
/test-masoutis-*.mjs
/test_masoutis_*.mjs

# local agent state
.claude/

# stray installers
public/logos/*.exe

# Local scratch from one-off scripts (resolver logs, tmp HTML/JSON probes)
.tmp_*
resolver-backlog.log

# local UX-review screenshots (scratch)
screenshots/

# local scratch
.shots.mjs
devserver.log

.vercel

# Capacitor native projects — generated by `npx cap add android|ios` and rebuilt
# in Android Studio / Xcode. Kept out of the repo for the dogfood phase; commit
# later (drop these lines) if you want reproducible CI builds.
/android
/ios
